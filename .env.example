# ============================================================
#  ResearchIQ — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# ── Groq API Key (LLM — FREE) ────────────────────────────────
# Get yours at: https://console.groq.com/keys
# Starts with: gsk_...
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── LLM Model Name ────────────────────────────────────────────
LLM_MODEL=openai/gpt-oss-120b

# ── MongoDB Atlas Connection String ───────────────────────────
# Get from: Atlas Dashboard → Connect → Drivers → copy string
# IMPORTANT: Replace <password> with your actual password (no angle brackets!)
MONGODB_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=research_impact_db

# ── JWT Secret Key ────────────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_your_64_char_random_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Local File Storage ────────────────────────────────────────
PAPERS_STORAGE_PATH=./data/papers
CHROMA_PERSIST_PATH=./data/chromadb

# ── Embedding Model (downloads once ~90 MB, then runs offline) ─
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Server Settings ───────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True
